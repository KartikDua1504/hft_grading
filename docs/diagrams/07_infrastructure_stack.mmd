        SG["Security Groups"]
        METAL["c8i.metal-48xl<br/>48 cores bare metal"]
        F2["f2.2xlarge<br/>FPGA Instance"]
    end

    FASTAPI --> REDIS
    FASTAPI --> QUESTDB
    FASTAPI --> REDPANDA
